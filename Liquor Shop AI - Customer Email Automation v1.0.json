      "parameters": {
        "jsCode": "const email = JSON.parse($json.output);\n\n// Recover the current customer from Call Inventory Service\nconst customer = $('Call \\'Inventory Service\\'').item.json;\n\nreturn [{\n  json: {\n    customer_email: customer.customer_email,\n    customer_query: customer.customer_query,\n    subject: email.subject,\n    body: email.body\n  }\n}];"
      },
